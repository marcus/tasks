#!/usr/bin/env ruby
# frozen_string_literal: true

# tasks — a tiny CLI over gtd.org
#
# Usage:
#   bin/tasks agenda        show items with SCHEDULED/DEADLINE, soonest first
#   bin/tasks next          list NEXT actions grouped by context
#   bin/tasks quadrants     Covey Important/Urgent 2x2
#   bin/tasks inbox         show unprocessed INBOX items
#   bin/tasks capture "..." append a new item to the Inbox
#
# Stdlib only — no bundler required. Parses gtd.org with simple line matching.

require "date"

ORG     = File.expand_path("../gtd.org", __dir__)
ARCHIVE = File.expand_path("../archive.org", __dir__)

Item = Struct.new(
  :state, :priority, :title, :tags, :scheduled, :deadline, :line, keyword_init: true
)

HEADLINE = /^\*+\s+(INBOX|TODO|NEXT|WAITING|DONE|CANCELLED)\s+(?:\[#([ABC])\]\s+)?(.*?)\s*(:[\w@:]+:)?\s*$/
STAMP    = /(SCHEDULED|DEADLINE):\s*<(\d{4}-\d{2}-\d{2})/

def parse
  items = []
  current = nil
  File.foreach(ORG, encoding: "UTF-8").with_index(1) do |line, lineno|
    if (m = line.match(HEADLINE))
      current = Item.new(
        state: m[1], priority: m[2], title: m[3].strip,
        tags: (m[4] || "").split(":").reject(&:empty?),
        scheduled: nil, deadline: nil, line: lineno
      )
      items << current
    elsif current && (s = line.match(STAMP))
      d = Date.parse(s[2])
      current.scheduled = d if s[1] == "SCHEDULED"
      current.deadline  = d if s[1] == "DEADLINE"
    end
  end
  items
end

def contexts(item) = item.tags.select { |t| t.start_with?("@") }
def open?(item)     = OPEN_STATES.include?(item.state)

OPEN_STATES = %w[INBOX TODO NEXT WAITING].freeze
DONE_STATES = %w[DONE CANCELLED].freeze

def headline_level(line) = line.match(/^(\*+)\s+/)&.captures&.first&.length
def headline_state(line) = line[/^\*+\s+(INBOX|TODO|NEXT|WAITING|DONE|CANCELLED)\b/, 1]

def color(str, code) = $stdout.tty? ? "\e[#{code}m#{str}\e[0m" : str
def bold(s)  = color(s, 1)
def dim(s)   = color(s, 90)
def red(s)   = color(s, 31)

def fmt(item)
  pri = item.priority ? "[#{item.priority}] " : ""
  ctx = contexts(item)
  tag = ctx.empty? ? "" : dim("  #{ctx.join(" ")}")
  "#{pri}#{item.title}#{tag}"
end

def cmd_next(items)
  nexts = items.select { |i| i.state == "NEXT" }
  by_ctx = Hash.new { |h, k| h[k] = [] }
  nexts.each do |i|
    ctxs = contexts(i)
    (ctxs.empty? ? ["(no context)"] : ctxs).each { |c| by_ctx[c] << i }
  end
  by_ctx.sort.each do |ctx, list|
    puts bold(ctx)
    list.sort_by { |i| i.priority || "Z" }.each { |i| puts "  #{fmt(i)}" }
    puts
  end
end

def cmd_quadrants(items)
  open_items = items.select { |i| open?(i) }
  q = {
    "Q1 · Important + Urgent  (do now)"        => ->(i) { i.tags.include?("important") && i.tags.include?("urgent") },
    "Q2 · Important, Not Urgent  (schedule)"   => ->(i) { i.tags.include?("important") && !i.tags.include?("urgent") },
    "Q3 · Urgent, Not Important  (delegate)"   => ->(i) { !i.tags.include?("important") && i.tags.include?("urgent") },
    "Q4 · Neither  (eliminate)"                => ->(i) { !i.tags.include?("important") && !i.tags.include?("urgent") },
  }
  q.each do |label, test|
    puts bold(label)
    matched = open_items.select(&test)
    matched.empty? ? (puts "  —") : matched.each { |i| puts "  #{fmt(i)}" }
    puts
  end
end

def cmd_agenda(items)
  dated = items.select { |i| open?(i) && (i.scheduled || i.deadline) }
  dated.sort_by { |i| i.deadline || i.scheduled }.each do |i|
    d = i.deadline || i.scheduled
    kind = i.deadline ? "DUE " : "STRT"
    days = (d - Date.today).to_i
    when_s = days.negative? ? "#{-days}d ago" : days.zero? ? "today" : "in #{days}d"
    stamp = "#{d} #{kind} (#{when_s})"
    stamp = red(stamp) if days <= 2
    puts "#{stamp}  #{fmt(i)}"
  end
end

def cmd_inbox(items)
  inbox = items.select { |i| i.state == "INBOX" }
  inbox.empty? ? (puts "Inbox empty. ✨") : inbox.each { |i| puts "  #{fmt(i)}" }
end

def cmd_capture(text)
  abort %(usage: tasks capture "...") if text.nil? || text.strip.empty?
  text = text.dup.force_encoding("UTF-8")
  lines = File.readlines(ORG, encoding: "UTF-8")
  inbox_idx = lines.index { |l| l =~ /^\* Inbox\b/ }
  abort "No '* Inbox' heading found in #{ORG}" unless inbox_idx
  # Insert just before the next top-level heading (end of the Inbox section).
  insert_idx = ((inbox_idx + 1)...lines.length).find { |i| lines[i] =~ /^\* / } || lines.length
  entry = "** INBOX #{text.strip}\n   Captured [#{Date.today}].\n\n"
  lines.insert(insert_idx, entry)
  File.write(ORG, lines.join)
  puts "Captured to Inbox: #{text.strip}"
end

def cmd_done(query)
  abort %(usage: tasks done "text") if query.nil? || query.strip.empty?
  q = query.dup.force_encoding("UTF-8").strip.downcase
  lines = File.readlines(ORG, encoding: "UTF-8")
  matches = lines.each_index.select do |i|
    st = headline_state(lines[i])
    st && OPEN_STATES.include?(st) && lines[i].downcase.include?(q)
  end
  abort "No open item matches: #{query}" if matches.empty?
  if matches.size > 1
    warn "Multiple matches — be more specific:"
    matches.each { |i| warn "  #{lines[i].strip}" }
    exit 1
  end
  i = matches.first
  lines[i] = lines[i].sub(/^(\*+\s+)(INBOX|TODO|NEXT|WAITING)\b/, '\1DONE')
  lines.insert(i + 1, "   CLOSED: [#{Date.today}]\n")
  File.write(ORG, lines.join)
  puts "Marked DONE: #{lines[i].strip}"
  puts "Run `tasks archive` to move it out of gtd.org."
end

def cmd_archive
  lines = File.readlines(ORG, encoding: "UTF-8")
  kept = []
  moved = []
  i = 0
  while i < lines.length
    st = headline_state(lines[i])
    if st && DONE_STATES.include?(st)
      level = headline_level(lines[i])
      block = [lines[i]]
      j = i + 1
      while j < lines.length
        lvl = headline_level(lines[j])
        break if lvl && lvl <= level # stop at next sibling/higher heading
        block << lines[j]
        j += 1
      end
      moved << block.join.rstrip + "\n"
      i = j
    else
      kept << lines[i]
      i += 1
    end
  end
  if moved.empty?
    puts "Nothing to archive (no DONE/CANCELLED items)."
    return
  end
  File.write(ORG, kept.join)
  arch = File.read(ARCHIVE, encoding: "UTF-8")
  arch << "\n" unless arch.end_with?("\n")
  arch << "\n# Archived #{Date.today}\n" << moved.join("\n") << "\n"
  File.write(ARCHIVE, arch)
  puts "Archived #{moved.size} item#{moved.size == 1 ? "" : "s"} to archive.org."
end

items = parse
case ARGV[0]
when "next"      then cmd_next(items)
when "quadrants" then cmd_quadrants(items)
when "agenda"    then cmd_agenda(items)
when "inbox"     then cmd_inbox(items)
when "capture"   then cmd_capture(ARGV[1..].join(" "))
when "done"      then cmd_done(ARGV[1..].join(" "))
when "archive"   then cmd_archive
else
  warn %(usage: tasks {agenda|next|quadrants|inbox|capture "..."|done "..."|archive})
  exit 1
end
