#!/usr/bin/env ruby
# frozen_string_literal: true

# tasks — a tiny CLI over tasks.jsonl
#
# Usage (each command has a single-letter alias):
#   bin/tasks agenda|a        show items with SCHEDULED/DEADLINE, soonest first
#   bin/tasks next|n          list NEXT actions grouped by context
#   bin/tasks quadrants|q     Covey 2x2 from priority+deadline (or important/urgent tags)
#   bin/tasks inbox|i         show unprocessed INBOX items
#   bin/tasks capture|c "..." append a new item (flags: --due/--scheduled/
#                             --priority/--tag/--context/--state/--project/--under)
#   bin/tasks done|d <ref>    mark a matching open item DONE (complete/close);
#                             cascades to its open descendants (recurring parent
#                             rolls forward instead and does not cascade)
#   bin/tasks due <ref> <date>       set/replace an item's DEADLINE
#   bin/tasks schedule <ref> <date>  set/replace an item's SCHEDULED
#   bin/tasks undate <ref> [--kind deadline|scheduled]  remove date stamp(s)
#   bin/tasks state <ref> <STATE>    transition an item to any state
#   bin/tasks cancel|drop <ref>      mark an item CANCELLED
#   bin/tasks priority <ref> <A|B|C|none>  set or clear the priority cookie
#   bin/tasks retitle <ref> "new title"    replace the headline title
#   bin/tasks tag <ref> +t -t @ctx -@ctx   add/remove tags and contexts
#   bin/tasks note <ref> "text"            append a body line under the task
#   bin/tasks move <ref> ("Section"|--under <ref>|--top)  relocate/nest/unnest a subtree
#   bin/tasks delete <ref>   hard-delete a task (needs --cascade if it has
#                             subtasks); undoable — usually prefer cancel/archive
#   bin/tasks recur <ref> <interval|off>   repeat on done (weekly, 2w, .+1m; off clears)
#   bin/tasks defer|snooze <ref>           hide a task (someday/maybe)
#   bin/tasks activate <ref>  bring a deferred task back (undefer/resume)
#   bin/tasks show|s <ref>    show one task in full (headline + notes)
#   bin/tasks archive|x       move DONE/CANCELLED items to archive.jsonl
#   bin/tasks list|l [...]    list tasks grouped by state, with filters:
#     scope:   --open/-o (default) --done/-d --archived/-x --all/-a
#     filters: @context  /text  +tag  -A|-B|-C  --deferred/-D (compose freely)
#   bin/tasks -p "..."        hand a natural-language request to an LLM agent
#                             (Claude or another configured harness), which acts
#                             on your tasks and reports what changed
#   bin/tasks config          show where tasks.jsonl/archive.jsonl and the
#                             agent-memory.md sidecar resolve, and why
#   bin/tasks help|-h         full command reference
#
# Stdlib only — no bundler required. Reads tasks.jsonl (one JSON record/line).
# Task files default to the repo root; point them elsewhere with TASKS_DIR
# (or TASKS_FILE/TASKS_ARCHIVE) env vars or ~/.config/tasks/config.

require "date"
require "shellwords"

ROOT    = File.expand_path("..", __dir__)
# Task files are configurable (env vars, ~/.config/tasks/config) so the data
# can live outside this repo. See lib/tasks/config.rb for precedence.
require_relative "../lib/tasks/config"
PATHS   = Tasks::Config.resolve(default_dir: ROOT)
ORG     = PATHS.org
ARCHIVE = PATHS.archive

# The model layer owns parsing and every mutation; the CLI adds dispatch,
# ref resolution, and output. (Tasks::Item, Tasks::Format etc. live there.)
require_relative "../lib/tasks/store"
require_relative "../lib/tasks/application"
require_relative "../lib/tasks/opener"

def contexts(item) = item.tags.select { |t| t.start_with?("@") }
def open?(item)     = OPEN_STATES.include?(item.state)

OPEN_STATES = Tasks::Store::OPEN_STATES
DONE_STATES = Tasks::Store::DONE_STATES

def color(str, code) = $stdout.tty? ? "\e[#{code}m#{str}\e[0m" : str
def bold(s)   = color(s, 1)
def dim(s)    = color(s, 90)
def red(s)    = color(s, 31)
def yellow(s) = color(s, 33)
def cyan(s)   = color(s, 36)

# Color a deadline by how close it is: red = overdue/today, yellow = next 2 days,
# cyan = this week, dim = further out.
def due_color(days)
  if    days <= 0 then 31
  elsif days <= 2 then 33
  elsif days <= 7 then 36
  else                 90
  end
end

# Short, colored date tag for `next`/`list`, e.g. "7/1" (no leading zeros).
# Prefers the DEADLINE; falls back to the SCHEDULED start date, marked with a
# leading "~" to distinguish "start" from "due". Empty when the item has
# neither. Colored by proximity (see due_color).
def short_due(item)
  date = item.deadline || item.scheduled
  return "" unless date
  days  = (date - Date.today).to_i
  label = "#{date.month}/#{date.day}"
  label = "~#{label}" unless item.deadline # scheduled = soft start date
  color(label, due_color(days))
end

def fmt(item)
  pri = item.priority ? "[#{item.priority}] " : ""
  ctx = contexts(item)
  tag = ctx.empty? ? "" : dim("  #{ctx.join(" ")}")
  "#{pri}#{item.title}#{tag}"
end

# Emit items as the standard JSON array (docs/cli-spec.md) and return true
# when --json was requested; read commands call this first.
def emit_json?(items, args, extra: nil, result: nil)
  return false unless args.include?("--json")
  require "json"
  rows = items.map do |i|
    h = item_json(i, task: result&.task_for(i))
    h.merge!(extra.call(i)) if extra
    h
  end
  puts JSON.generate(rows)
  true
end

def cmd_next(args = [])
  result = application.view_tasks(:next)
  nexts = result.items
  return if emit_json?(nexts, args, result: result)
  by_ctx = Hash.new { |h, k| h[k] = [] }
  nexts.each do |i|
    ctxs = contexts(i)
    (ctxs.empty? ? ["(no context)"] : ctxs).each { |c| by_ctx[c] << i }
  end
  by_ctx.sort.each do |ctx, list|
    puts bold(ctx)
    # The canonical :next order is already priority-sorted with file-order
    # ties; a per-group re-sort here would re-break those ties (MRI sort_by
    # is unstable).
    list.each do |i|
      due = short_due(i)
      puts "  #{fmt(i)}#{due.empty? ? "" : "  #{due}"}"
    end
    puts
  end
end

def cmd_quadrants(args = [])
  result = application.view_tasks(:quadrants, urgent_days: PATHS.urgent_days)
  open_items = result.items
  return if emit_json?(open_items, args, result: result, extra: ->(i) { result.metadata_for(i) })
  by_q = open_items.group_by { |item| result.metadata_for(item).fetch(:quadrant) }
  Tasks::Quadrants::LABELS.each do |key, label|
    puts bold(label)
    matched = by_q[key] || []
    matched.empty? ? (puts "  —") : matched.each { |i| puts "  #{fmt(i)}" }
    puts
  end
end

def cmd_agenda(args = [])
  result = application.view_tasks(:agenda)
  dated = result.items
  return if emit_json?(dated, args, result: result)
  dated.each do |i|
    d = i.deadline || i.scheduled
    kind = i.deadline ? "DUE " : "STRT"
    days = (d - Date.today).to_i
    when_s = days.negative? ? "#{-days}d ago" : days.zero? ? "today" : "in #{days}d"
    stamp = "#{d.strftime("%m-%d")} #{kind} (#{when_s})"
    stamp = red(stamp) if days <= 2
    puts "#{stamp}  #{fmt(i)}"
  end
end

def cmd_inbox(args = [])
  result = application.view_tasks(:inbox)
  inbox = result.items
  return if emit_json?(inbox, args, result: result)
  inbox.empty? ? (puts "Inbox empty. ✨") : inbox.each { |i| puts "  #{fmt(i)}" }
end

CAPTURE_USAGE = %(usage: tasks capture "text" [--due d] [--scheduled d] [--priority A|B|C] [--tag t] [--context @x] [--state STATE] [--project "Heading" | --under <ref>])

def cmd_capture(args)
  require_relative "../lib/tasks/dates"
  tags = []
  contexts = []
  due = scheduled = priority = state = project = recur = under = nil
  dry = json = false
  positional = []
  i = 0
  # fetch a flag's value or abort — a forgotten value must never fail silently
  need = ->(flag) { args[i += 1] or abort "missing value for #{flag}" }
  while i < args.length
    case (a = args[i])
    when "--due", "--deadline"    then due = need.(a)
    when "--scheduled", "--sched" then scheduled = need.(a)
    when "--priority", "--pri"    then priority = need.(a)
    when "--tag"                  then tags << need.(a)
    when "--context", "--ctx"     then contexts << need.(a)
    when "--state"                then state = need.(a)
    when "--project"              then project = need.(a)
    when "--under"                then under = need.(a)
    when "--recur", "--repeat"    then recur = need.(a)
    when "--dry-run"              then dry = true
    when "--json"                 then json = true
    when /\A--/                   then abort "unknown flag: #{a}"
    else                               positional << a
    end
    i += 1
  end
  text = positional.join(" ").strip.force_encoding("UTF-8")
  abort CAPTURE_USAGE if text.empty?
  # --under (nest under a task) and --project (file under a section) are two
  # different destinations — pick one.
  abort "can't combine --under and --project\n#{CAPTURE_USAGE}" if under && project

  cookie = nil
  if recur
    require_relative "../lib/tasks/recur"
    cookie = Tasks::Recur.parse_interval(recur)
    abort "unrecognized interval: #{recur} (try weekly, 2w, .+1m)" if cookie.nil? || cookie == :off
    # A recurrence needs a date to repeat; default to scheduling it today.
    scheduled ||= "today" unless due
  end

  due_date = due && (Tasks::Dates.parse_when(due) || abort("unrecognized date: #{due}"))
  scheduled_date = scheduled && (Tasks::Dates.parse_when(scheduled) || abort("unrecognized date: #{scheduled}"))

  pri = priority&.upcase
  pri = nil if pri && %w[NONE CLEAR -].include?(pri)
  abort "priority must be A, B, or C" unless pri.nil? || %w[A B C].include?(pri)

  st = state&.upcase || ((due_date || scheduled_date) ? "TODO" : "INBOX")
  valid = OPEN_STATES + DONE_STATES
  abort "unknown state: #{st} (want one of #{valid.join(", ")})" unless valid.include?(st)
  abort "can't set recurrence on a #{st} task" if cookie && DONE_STATES.include?(st)

  # Contexts are tags that start with "@"; list them before plain tags.
  all_tags = contexts.map { |c| c.start_with?("@") ? c : "@#{c}" } + tags

  # --under nests below an existing task (open-only ref, exit 2 on miss).
  # Resolve the convenience ref here, then pass only its durable id across the
  # application boundary.
  under_item = under && resolve_ref(under)
  parent_id = under_item && stable_id_for(under_item)

  if dry
    head = +"#{st} "
    head << "[##{pri}] " if pri
    head << text
    head << " :#{all_tags.join(":")}:" unless all_tags.empty?
    head << " (recur #{cookie})" if cookie
    if under_item
      puts %(would capture under "#{under_item.title}": #{head})
    else
      puts "would capture under #{project || "Inbox"}: #{head}"
    end
    return
  end

  command = Tasks::CreateTask.new(
    title: text, deadline: due_date, scheduled: scheduled_date,
    priority: pri, tags: all_tags, state: st, project: project,
    parent_id: parent_id, recurrence: cookie
  )
  result = application.create_task(command)
  if result.too_deep?
    mutation_failed "would exceed max depth #{store.max_depth} (max_depth config / TASKS_MAX_DEPTH)"
  end
  # A parent can disappear after the CLI resolved --under. That is a stale
  # mutation (exit 1), not a fresh ref-resolution miss (exit 2).
  if result.not_found? && parent_id
    result = Tasks::MutationResult.new(status: :stale, errors: result.errors,
                                        field_errors: result.field_errors,
                                        form_errors: result.form_errors,
                                        touched_ids: result.touched_ids, summary: result.summary)
  end
  mutation_result_failed(result, "could not capture (no #{(project || "Inbox").inspect} section found?)")
  report_touched(result.touched_ids, json: json)
end

# Core of the state-transition verbs. `state` passes the target as a
# positional arg; its sugar `done`/`cancel` hardcode DONE/CANCELLED. All three
# resolve the ref, honor --dry-run/--json, and route the write through the
# stable-id state patch (which stamps/clears CLOSED). `resolve_closed:` widens ref
# resolution to closed tasks — always for `state` (so you can reopen a DONE
# item), on demand elsewhere via --include-done.
def change_state(args, usage:, resolve_closed:, to: nil, dry_verb: nil, archive_hint: false, recur_aware: false)
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  target = to || rest.join(" ").strip.upcase
  abort %(usage: #{usage}) if ref.nil? || ref.strip.empty? || target.empty?
  valid = OPEN_STATES + DONE_STATES
  abort "unknown state: #{target} (want one of #{valid.join(", ")})" unless valid.include?(target)

  item = resolve_ref(ref, include_done: resolve_closed || flags["--include-done"])
  # Completing a recurring task rolls its date forward and keeps it open — a
  # different verb (and no archive hint) than closing a one-shot task.
  recurring_done = recur_aware && target == "DONE" && item.recurring?
  if flags["--dry-run"]
    if recurring_done
      puts "would recur → #{recur_next(item).iso8601}: #{item_headline(item)}"
    else
      puts "would #{dry_verb || "set state #{target} on"}: #{item_headline(item)}"
      # Completing an open parent cascades to its open descendants; preview how
      # many would close so a `done` on a project isn't a silent surprise. Gated
      # on an actual transition into DONE (item still open), matching the store.
      if target == "DONE" && item.open? && (n = open_descendant_count(item)) > 0
        puts "would also close #{n} open descendant#{"s" unless n == 1}"
      end
    end
    return
  end
  task_id = stable_id_for(item)
  result = patch_task_by_id(task_id, field: :state, value: target,
                            label: "state → #{target}: #{item.title}")
  mutation_result_failed(result, "failed to set state")
  if recurring_done && !flags["--json"]
    fresh = store.items.find { |i| i.id == task_id }
    d = fresh && (fresh.deadline || fresh.scheduled)
    puts "↻ #{item.title}#{d ? " → next #{d.iso8601} (#{d.strftime("%a")})" : ""}"
  end
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
  puts "Run `tasks archive` to move it out of tasks.jsonl." if archive_hint && !recurring_done && !flags["--json"]
end

# The date a recurring item's next occurrence would land on, from its precedence
# stamp (DEADLINE over SCHEDULED, matching the Store). For `done` preview output.
def recur_next(item)
  require_relative "../lib/tasks/recur"
  base = item.deadline || item.scheduled
  Tasks::Recur.next_date(item.recur, from: base)
end

# `done` and `cancel` are sugar for the DONE/CANCELLED transitions; they resolve
# open tasks only (a closed task needs `state` to reopen or re-close it).
def cmd_done(args)
  change_state(args, to: "DONE", usage: %(tasks done "<ref>"),
               resolve_closed: false, dry_verb: "mark DONE", archive_hint: true, recur_aware: true)
end

def cmd_cancel(args)
  change_state(args, to: "CANCELLED", usage: "tasks cancel <ref>", resolve_closed: false)
end

# --- Store-backed mutations (due / state / priority) ------------------------
#
# These go through Tasks::Store#with_history, which validates the file after
# every write and rolls back on structural error. Ref resolution matches a
# case-insensitive substring of an open task's title, or an exact `L<line>`.

def store
  @store ||= Tasks::Store.new(org: ORG, archive: ARCHIVE,
                              links: PATHS.links, link_systems: PATHS.link_systems,
                              max_depth: PATHS.max_depth)
end

# The application keeps no Store instance: every query receives its own fresh
# Store and immutable snapshot. The CLI's long-lived Store above remains for
# CLI-only ref resolution, presentation, and the remaining non-patch commands.
def application
  @application ||= Tasks::Application.new(
    store_factory: Tasks::StoreFactory.new(
      org: ORG, archive: ARCHIVE, links: PATHS.links,
      link_systems: PATHS.link_systems, max_depth: PATHS.max_depth
    )
  )
end

# Abort a failed mutation. A false return is usually a stale line, but it's also
# how a post-write validation rollback surfaces — if the store recorded one,
# append a pointed hint so the user runs `check` instead of chasing a phantom
# concurrent edit.
def mutation_failed(msg)
  if store.last_rollback
    abort "#{msg}\nfile failed validation after the edit — run `tasks check`"
  else
    abort msg
  end
end

# CLI refs are deliberately fuzzy and may use L<line>, but that convenience
# ends at the command boundary. Every write below addresses its target by the
# stable id returned from ref resolution.
def stable_id_for(item)
  return item.id if item.id && !item.id.empty?

  mutation_failed "task has no stable id"
end

PATCH_EXPECTED_UNSET = Object.new.freeze
PATCH_SNAPSHOT_UNSET = Object.new.freeze

# Build one stable-id patch from a fresh editor snapshot. A ref can disappear
# after the CLI resolved it; that is the legacy stale-edit case (exit 1), while
# refs that are absent at resolution still exit 2 in resolve_ref.
def patch_task_by_id(task_id, field:, value:, label:, expected: PATCH_EXPECTED_UNSET,
                     coalesce_key: nil, snapshot: PATCH_SNAPSHOT_UNSET, force: false)
  snapshot = application.edit_snapshot(task_id) if snapshot.equal?(PATCH_SNAPSHOT_UNSET)
  baseline = if expected.equal?(PATCH_EXPECTED_UNSET)
               snapshot && patch_expected(snapshot, field)
             else
               expected
             end
  patch = Tasks::TaskPatch.new(id: task_id, field: field, value: value,
                               expected: baseline, history_label: label,
                               coalesce_key: coalesce_key, force: force)
  result = application.patch_task(patch)
  return result unless result.not_found?

  Tasks::MutationResult.new(status: :stale, snapshot: result.snapshot,
                             errors: result.errors, field_errors: result.field_errors,
                             form_errors: result.form_errors,
                             touched_ids: result.touched_ids, summary: result.summary)
end

def patch_expected(snapshot, field)
  return snapshot.metadata.fetch(:tag_sequence) if field == :tag_delta
  return snapshot.metadata.fetch(:date_state) if field == :date_clear

  snapshot.expected_for(field)
end

# Adapter mapping for typed Store results. Human wording remains the command's
# established wording; the result supplies the exit status after the command
# has already distinguished ref-resolution failures from stale writes.
def mutation_result_failed(result, msg)
  return result if result.ok?

  # last_rollback distinguishes a write that failed validation and rolled back
  # from a preflight refusal that never wrote (the file was already invalid).
  message = if store.last_rollback
              "#{msg}\nfile failed validation after the edit — run `tasks check`"
            elsif result.store_invalid?
              "#{msg}\ntask file is already invalid — run `tasks check` (nothing was written)"
            else
              msg
            end
  warn message
  exit result.cli_exit_code
end

def result_touched_ids(result, fallback:)
  result.touched_ids.empty? ? [fallback] : result.touched_ids
end

# Match Store's legacy top-level section lookup at the CLI boundary, then pass
# only the section id into the location patch.
def section_id_for(name)
  want = name.strip.downcase
  records = store.read_snapshot.live_records
  sections = records.select { |record| record["type"] == "section" && !record["parent"] }
  section = sections.find { |record| record["title"].to_s.downcase == want } ||
            sections.find { |record| record["title"].to_s.downcase.include?(want) }
  section && section["id"]
end

# Locate the task's nearest ancestor section by id without retaining a file
# coordinate. Rootless tasks have no top-level destination, matching the old
# move_top! refusal.
def nearest_section_id_for(task_id)
  records = store.read_snapshot.live_records
  by_id = records.to_h { |record| [record["id"], record] }
  record = by_id[task_id]
  record = record && record["parent"] && by_id[record["parent"]]
  while record && record["type"] != "section"
    # A nil parent must stop the walk (rootless ancestor chain) — without the
    # guard, by_id[nil] resolves to the id-less meta record, whose parent is
    # also nil, and the loop cycles on it forever.
    record = record["parent"] && by_id[record["parent"]]
  end
  record && record["id"]
end

# Pull known boolean flags out of args, returning [flags_hash, positional].
def take_flags(args, *known)
  flags = {}
  rest = []
  args.each do |a|
    if known.include?(a)
      flags[a] = true
    elsif a.start_with?("--")
      abort "unknown flag: #{a} (this command accepts: #{known.join(", ")})"
    else
      rest << a
    end
  end
  [flags, rest]
end

def item_headline(item)
  store.headline(item)
end

def item_json(item, task: nil)
  # One map, one insertion order. When a TaskView is present every semantic
  # field is read from it (source/headline/contexts included); otherwise the
  # Item supplies them — both respond to the same readers, so adding or
  # renaming a field can't split the JSON shape between read commands and
  # mutation reporting. `line` is always the item's physical line.
  src = task || item
  {
    id: src.id,
    state: src.state, priority: src.priority, title: src.title,
    tags: src.tags.reject { |tag| tag.start_with?("@") },
    contexts: src.contexts,
    scheduled: src.scheduled&.iso8601, deadline: src.deadline&.iso8601,
    recur: src.recur,
    line: item.line, source: src.source, headline: src.headline,
  }
end

# Resolve <ref> to exactly one open item (or exit 2). `L<line>` targets an
# exact headline line. --include-done widens the search to closed items.
def resolve_ref(ref, include_done: false)
  abort "missing <ref>" if ref.nil? || ref.strip.empty?
  items = store.items
  items = items.select { |i| OPEN_STATES.include?(i.state) } unless include_done

  if (m = ref.match(/\AL(\d+)\z/i))
    item = items.find { |i| i.line == m[1].to_i }
    unless item
      warn "no #{include_done ? "" : "open "}task with a headline on line #{m[1]}"
      exit 2
    end
    return item
  end

  # An exact :ID: match is unambiguous, so it wins over fuzzy title matching
  # (case-insensitive, since org treats property values loosely).
  if (item = items.find { |i| i.id && i.id.casecmp?(ref.strip) })
    return item
  end

  q = ref.dup.force_encoding("UTF-8").strip.downcase
  # to_s: a nil-title record (a prime repair target) must be resolvable by
  # fuzzy ref without a NoMethodError; it simply won't match any substring.
  matches = items.select { |i| i.title.to_s.downcase.include?(q) }
  if matches.empty?
    warn "no match: #{ref}"
    exit 2
  elsif matches.size > 1
    warn "ambiguous: #{ref} — matches #{matches.size} tasks:"
    matches.each { |i| warn "  L#{i.line}: #{item_headline(i)}" }
    exit 2
  end
  matches.first
end

# After a mutation, print (or JSON-emit) every touched task's new headline.
# Stable ids survive retitles and tree moves, and cascade results carry every
# affected id. The CLI JSON keeps its historical line field as presentation,
# never as a mutation locator.
def report_touched(ids, json:)
  store.reload!
  items = Array(ids)
         .map { |id| store.items.find { |i| i.id == id } }
         .compact.sort_by(&:line)
  if json
    require "json"
    puts({ touched: items.map { |i| item_json(i) } }.to_json)
  else
    items.each { |i| puts item_headline(i) }
  end
end

# How many open tasks sit below `item` in the tree — the descendants a `done`
# cascade would close. Read-side count over the item's tree node (self dropped);
# 0 when the item has no live node (e.g. an archive item), so the caller stays
# silent rather than guessing.
def open_descendant_count(item)
  node = store.node_for(item)
  return 0 unless node
  node.each.drop(1).count { |n| n.item&.open? }
end

# Shared implementation for `due` (DEADLINE) and `schedule` (SCHEDULED).
def cmd_set_date(args, kind:, usage:)
  require_relative "../lib/tasks/dates"
  key = kind == :scheduled ? "SCHEDULED" : "DEADLINE"
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  date_str = rest.join(" ")
  abort %(usage: #{usage}) if ref.nil? || date_str.strip.empty?
  date = Tasks::Dates.parse_when(date_str)
  abort "unrecognized date: #{date_str}" unless date

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  if flags["--dry-run"]
    puts "would set #{key} <#{date.iso8601} #{date.strftime("%a")}> on: #{item_headline(item)}"
    return
  end
  result = patch_task_by_id(task_id, field: kind, value: date,
                            label: "#{key.downcase} → #{date.iso8601}: #{item.title}")
  mutation_result_failed(result, "failed to set #{key.downcase}")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

def cmd_due(args)      = cmd_set_date(args, kind: :deadline,  usage: "tasks due <ref> <date>")
def cmd_schedule(args) = cmd_set_date(args, kind: :scheduled, usage: "tasks schedule <ref> <date>")

def cmd_priority(args)
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  pri_arg = rest.join(" ").strip
  abort %(usage: tasks priority <ref> <A|B|C|none>) if ref.nil? || pri_arg.empty?
  pri = pri_arg.upcase
  pri = nil if %w[NONE CLEAR -].include?(pri)
  abort "priority must be A, B, C, or none" unless pri.nil? || %w[A B C].include?(pri)

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  if flags["--dry-run"]
    puts "would set priority #{pri ? "[##{pri}]" : "(none)"} on: #{item_headline(item)}"
    return
  end
  label = pri ? "priority [##{pri}]: #{item.title}" : "clear priority: #{item.title}"
  result = patch_task_by_id(task_id, field: :priority, value: pri, label: label)
  mutation_result_failed(result, "failed to set priority")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

def cmd_undate(args)
  args = args.dup
  kind = nil
  if (idx = args.index("--kind"))
    kind_arg = args[idx + 1]
    abort "usage: tasks undate <ref> [--kind deadline|scheduled]" unless kind_arg
    args.delete_at(idx + 1)
    args.delete_at(idx)
    kind = kind_arg.downcase.to_sym
    abort "--kind must be deadline or scheduled" unless %i[deadline scheduled].include?(kind)
  end

  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  abort %(usage: tasks undate <ref> [--kind deadline|scheduled]) if ref.nil? || ref.strip.empty?

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  if flags["--dry-run"]
    target = kind ? kind.to_s.upcase : "SCHEDULED/DEADLINE"
    puts "would remove #{target} from: #{item_headline(item)}"
    return
  end
  label = kind ? "remove #{kind}: #{item.title}" : "remove dates: #{item.title}"
  snapshot = application.edit_snapshot(task_id)
  if snapshot && !(kind ? snapshot.public_send(kind) : snapshot.scheduled || snapshot.deadline)
    mutation_failed "nothing to remove (no matching date stamp?)"
  end
  result = patch_task_by_id(task_id, field: :date_clear, value: kind, label: label,
                            snapshot: snapshot)
  mutation_result_failed(result, "nothing to remove (no matching date stamp?)")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

def cmd_show(args)
  flags, rest = take_flags(args, "--json", "--include-done")
  ref = rest.shift
  abort %(usage: tasks show <ref>) if ref.nil? || ref.strip.empty?
  item = resolve_ref(ref, include_done: flags["--include-done"])
  # Show is a pure read: build the view over one snapshot and fall back to the
  # held item if a concurrent write removed it, instead of aborting with
  # mutation-flavored error text (and a misleading rollback hint).
  task = Tasks::TaskQueries.new(store.read_snapshot).task(item)

  closed = task.closed
  notes = task.body.map(&:strip).reject(&:empty?)
  links = task.links
  project = task.project

  if flags["--json"]
    require "json"
    puts item_json(item, task: task).merge(
      closed: closed&.iso8601, notes: notes, project: project,
      links: links.map(&:to_h),
    ).to_json
  else
    puts task.headline
    puts "  id:        #{task.id}" if task.id
    puts "  project:   #{project}" if project
    puts "  scheduled: #{task.scheduled.iso8601}" if task.scheduled
    puts "  deadline:  #{task.deadline.iso8601}" if task.deadline
    puts "  recur:     #{task.recur} #{dim("(#{recur_summary(task.recur)})")}" if task.recur
    puts "  closed:    #{closed.iso8601}" if closed
    notes.each { |n| puts "  #{n}" }
    unless links.empty?
      width = links.map { |l| l.system.length }.max
      links.each { |l| puts link_line(l, width) }
    end
  end
end

# List links found in task titles/bodies, classified by system (slack, jira,
# github, …). One task's links with a <ref>; otherwise every open task's.
# --system filters (e.g. --system jira); --all widens to done + archived.
# Shared --system value parsing for `links` and `open` — the two must agree
# on how a system name is read (downcased: SYSTEMS names and host fallbacks
# are lowercase) or "open what links showed me" breaks between them.
def take_system_value(args)
  value = args.shift
  abort "--system needs a value" if value.nil? || value.start_with?("-")
  value.downcase
end

def cmd_links(args)
  args = args.dup
  flags = {}
  system_f = nil
  rest = []
  until args.empty?
    a = args.shift
    case a
    when "--json"         then flags["--json"] = true
    when "--all", "-a"    then flags["--all"] = true
    when "--system", "-s" then system_f = take_system_value(args)
    when /\A-/            then abort "unknown flag: #{a} (links accepts: --json, --all, --system)"
    else                       rest << a
    end
  end

  entries =
    if (ref = rest.shift)
      item = resolve_ref(ref, include_done: true)
      [[item, store.links(item)]]
    else
      items = store.items
      items += store.archive_items if flags["--all"]
      items = items.select { |i| flags["--all"] || OPEN_STATES.include?(i.state) }
      items.map { |i| [i, store.links(i)] }
    end
  entries = entries.map { |i, ls| [i, system_f ? ls.select { |l| l.system == system_f } : ls] }
                   .reject { |_i, ls| ls.empty? }

  if flags["--json"]
    require "json"
    puts({ links: entries.flat_map { |i, ls|
      ls.map { |l| l.to_h.merge(task: i.title, id: i.id, line: i.line, source: i.source) }
    } }.to_json)
    return
  end

  if entries.empty?
    puts "No links found."
    return
  end
  width = entries.flat_map { |_i, ls| ls.map { |l| l.system.length } }.max
  entries.each do |i, ls|
    puts fmt(i)
    ls.each { |l| puts link_line(l, width) }
  end
end

# One rendered link row, shared by `links` and `show` so the surfaces agree.
def link_line(link, width)
  "  #{cyan(link.system.ljust(width))} #{link.url}#{link.label ? dim("  (#{link.label})") : ""}"
end

# Open a task's link in the browser. One link opens straight away; several
# need a pick — a 1-based index or --system — otherwise they're listed with a
# hint (nothing launches unbidden). --print prints instead of launching.
def cmd_open(args)
  args = args.dup
  flags = {}
  system_f = nil
  rest = []
  until args.empty?
    a = args.shift
    case a
    when "--print", "-p"  then flags["--print"] = true
    when "--system", "-s" then system_f = take_system_value(args)
    when /\A-/            then abort "unknown flag: #{a} (open accepts: --print, --system)"
    else                       rest << a
    end
  end
  ref = rest.shift
  abort "usage: tasks open <ref> [n] [--system <name>] [--print]" if ref.nil? || ref.strip.empty?
  pick = rest.shift&.then { |n| n =~ /\A\d+\z/ ? n.to_i : abort("expected a link number, got: #{n}") }

  item = resolve_ref(ref, include_done: true)
  links = store.links(item)
  links = links.select { |l| l.system == system_f } if system_f
  abort "no links on: #{item.title}#{system_f ? " (system #{system_f})" : ""}" if links.empty?

  if pick
    # 1-based; 0 would negative-index into the list's tail
    abort "no link ##{pick} (task has #{links.size})" unless pick >= 1 && links[pick - 1]
    link = links[pick - 1]
  elsif links.size == 1
    link = links.first
  else
    # Echo the --system filter in the hint: the numbers below index the
    # FILTERED list, so the re-run must filter the same way.
    sys = system_f ? " --system #{system_f}" : ""
    warn "#{links.size} links — pick one: tasks open #{ref.inspect}#{sys} <n>"
    width = links.map { |l| l.system.length }.max
    links.each_with_index { |l, i| warn "  #{i + 1}. #{cyan(l.system.ljust(width))} #{l.url}" }
    exit 1
  end

  if flags["--print"]
    puts link.url
  else
    Tasks::Opener.open_url(link.url) or abort "no browser launcher found (set TASKS_OPENER)"
    puts "opened #{link.url}"
  end
end

def cmd_state(args)
  usage = "tasks state <ref> <#{(OPEN_STATES + DONE_STATES).join("|")}>"
  # resolve_closed: true — a state change may need to find (and reopen) a
  # closed item, e.g. `state <ref> TODO`. recur_aware: DONE on a recurring task
  # rolls it forward (same as `done`), so the preview/output must say so.
  change_state(args, usage: usage, resolve_closed: true, recur_aware: true)
end

def cmd_retitle(args)
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  new_title = rest.join(" ").strip
  abort %(usage: tasks retitle <ref> "new title") if ref.nil? || ref.strip.empty? || new_title.empty?

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  if flags["--dry-run"]
    puts "would retitle to #{new_title.inspect}: #{item_headline(item)}"
    return
  end
  result = patch_task_by_id(task_id, field: :title, value: new_title,
                            label: "retitle → #{new_title}: #{item.title}")
  mutation_result_failed(result, "failed to retitle")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

def cmd_tag(args)
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  specs = rest
  abort %(usage: tasks tag <ref> +tag -tag @ctx -@ctx) if ref.nil? || ref.strip.empty? || specs.empty?

  add = []
  remove = []
  specs.each do |s|
    case s
    when /\A-(.+)/  then remove << Regexp.last_match(1)  # -tag or -@ctx
    when /\A\+(.+)/ then add << Regexp.last_match(1)     # +tag
    when /\A@/      then add << s                        # @ctx
    else abort "tag spec must start with +, -, or @: #{s}"
    end
  end

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  if flags["--dry-run"]
    changes = (add.map { |t| "+#{t}" } + remove.map { |t| "-#{t}" }).join(" ")
    puts "would apply #{changes} to: #{item_headline(item)}"
    return
  end
  result = patch_task_by_id(task_id, field: :tag_delta,
                            value: { add: add, remove: remove },
                            label: "tags: #{item.title}")
  mutation_result_failed(result, "failed to update tags")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

# ARGV strings carry the locale's encoding (ASCII-8BIT under LANG=C, cron,
# scripts); re-tag as UTF-8 before joining with snapshot text, or the
# interpolation below raises Encoding::CompatibilityError on a non-ASCII body.
# Same recovery Store#utf8 applies to the value once it reaches the patch.
def utf8_arg(str)
  return str if str.nil? || str.encoding == Encoding::UTF_8
  recoded = str.dup.force_encoding(Encoding::UTF_8)
  recoded.valid_encoding? ? recoded : str
end

def cmd_note(args)
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  text = utf8_arg(rest.join(" ").strip)
  abort %(usage: tasks note <ref> "text") if ref.nil? || ref.strip.empty? || text.empty?

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  if flags["--dry-run"]
    puts "would add note to #{item_headline(item)}: #{text}"
    return
  end
  snapshot = application.edit_snapshot(task_id)
  body = snapshot&.body
  result = patch_task_by_id(task_id, field: :body,
                            value: body.nil? || body.empty? ? text.strip : "#{body}\n#{text.strip}",
                            label: "note: #{item.title}", snapshot: snapshot)
  mutation_result_failed(result, "failed to add note")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

# `defer` and `activate` toggle the semantic `defer` tag (someday/maybe).
# Deferring hides a task from the active views without touching its state;
# activating brings it back. Both share the standard mutation flag handling.
def cmd_defer(args, deferred:, usage:, verb:)
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  abort %(usage: #{usage}) if ref.nil? || ref.strip.empty?

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  if flags["--dry-run"]
    puts "would #{verb}: #{item_headline(item)}"
    return
  end
  label = deferred ? "defer: #{item.title}" : "activate: #{item.title}"
  result = patch_task_by_id(task_id, field: :deferred, value: deferred, label: label)
  mutation_result_failed(result, "failed to #{verb}")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

# Human-readable gloss of a repeater cookie, e.g. ".+1w" → "every 1 week, from
# completion". Used by `show` and `recur` output.
def recur_summary(cookie)
  m = cookie.to_s.match(/\A(\.\+|\+\+|\+)(\d+)([dwmy])\z/)
  return cookie unless m
  unit = { "d" => "day", "w" => "week", "m" => "month", "y" => "year" }[m[3]]
  n = m[2].to_i
  anchor = { ".+" => "from completion", "+" => "fixed", "++" => "catch-up" }[m[1]]
  "every #{n} #{unit}#{n == 1 ? "" : "s"}, #{anchor}"
end

# Attach/replace/clear a recurrence repeater on a task's date stamp. On `done`,
# a recurring task rolls its date forward and stays open instead of closing.
# `<interval>`: a cookie (.+1w/+2d/++1m) or friendly form (weekly/2w/every 3 days),
# or `off` to clear. --from schedule|completion picks +/.+ for a bare interval;
# --on <date> seeds a stamp when the task has no date yet.
def cmd_recur(args)
  require_relative "../lib/tasks/dates"
  require_relative "../lib/tasks/recur"
  args = args.dup

  from = extract_value(args, "--from")
  abort "--from must be schedule or completion" unless from.nil? || %w[schedule completion].include?(from)
  on = extract_value(args, "--on")
  on_date = on && (Tasks::Dates.parse_when(on) || abort("unrecognized date: #{on}"))

  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done")
  ref = rest.shift
  interval = rest.join(" ").strip
  abort %(usage: tasks recur <ref> <weekly|2w|.+1m|off> [--from schedule|completion] [--on <date>]) if ref.nil? || ref.strip.empty? || interval.empty?

  default_prefix = from == "schedule" ? "+" : ".+"
  cookie = Tasks::Recur.parse_interval(interval, default_prefix: default_prefix)
  abort "unrecognized interval: #{interval} (try weekly, 2w, every 3 days, .+1m, or off)" if cookie.nil?

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  # A closed task with a live repeater is dead recurrence: `done` can't reach it
  # to roll it. Refuse to create one (clearing with `off` is always fine).
  if cookie != :off && DONE_STATES.include?(item.state)
    abort "can't set recurrence on a #{item.state} task — reopen it first"
  end
  has_date = item.scheduled || item.deadline
  if cookie != :off && !has_date && on_date.nil?
    abort "“#{item.title}” has no date to repeat — add --on <date>, or schedule/`due` it first"
  end
  # Clearing recurrence from a task that has no date (so can't be recurring) is
  # a harmless no-op, not an error.
  noop_off = cookie == :off && !has_date

  if flags["--dry-run"]
    desc =
      if noop_off        then "leave unchanged (no recurrence set)"
      elsif cookie == :off then "clear recurrence"
      else                    "set recurrence #{cookie} (#{recur_summary(cookie)})"
      end
    desc += ", seeding DEADLINE <#{on_date.iso8601}>" if on_date && !has_date
    puts "would #{desc} on: #{item_headline(item)}"
    return
  end

  if noop_off
    report_touched([task_id], json: flags["--json"])
    return
  end
  if on_date && !has_date
    result = patch_task_by_id(task_id, field: :deadline, value: on_date,
                              label: "deadline → #{on_date.iso8601}: #{item.title}")
    mutation_result_failed(result, "failed to seed date")
  end
  label = cookie == :off ? "recur off: #{item.title}" : "recur #{cookie}: #{item.title}"
  result = patch_task_by_id(task_id, field: :recurrence, value: cookie, label: label)
  mutation_result_failed(result, "failed to set recurrence (no date stamp?)")
  report_touched(result_touched_ids(result, fallback: task_id), json: flags["--json"])
end

# Pull `--flag value` out of args in place, returning the value (or nil). Aborts
# if the flag is present without a following value. For value flags that
# take_flags (boolean-only) can't handle.
def extract_value(args, flag)
  idx = args.index(flag)
  return nil unless idx
  val = args[idx + 1]
  abort "missing value for #{flag}" if val.nil? || val.start_with?("--")
  args.delete_at(idx + 1)
  args.delete_at(idx)
  val
end

MOVE_USAGE = %(tasks move <ref> ("Section" | --under <ref> | --top))

# Relocate a task's subtree. Exactly one destination: a positional section
# name, --under <ref> (nest below another task, depth-capped), or --top (unnest
# to the section level). --top and moves to a section are never depth-checked.
def cmd_move(args)
  args = args.dup
  under = extract_value(args, "--under")
  flags, rest = take_flags(args, "--dry-run", "--json", "--include-done", "--top")
  ref = rest.shift
  section = rest.join(" ").strip
  top = flags["--top"]
  abort %(usage: #{MOVE_USAGE}) if ref.nil? || ref.strip.empty?
  # Exactly one destination.
  abort %(usage: #{MOVE_USAGE}) unless [!section.empty?, !under.nil?, top].count(true) == 1

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)

  if top
    if flags["--dry-run"]
      puts "would unnest to top level: #{item_headline(item)}"
      return
    end
    section_id = nearest_section_id_for(task_id)
    mutation_failed "failed to unnest" unless section_id
    result = patch_task_by_id(task_id, field: :location, value: section_id,
                              label: "unnest: #{item.title}")
    mutation_result_failed(result, "failed to unnest")
    if result.no_change?
      # Already parented to its section — nothing to do (and no undo slot burned).
      puts "already at top level"
      puts item_headline(item)
    else
      report_touched([task_id], json: flags["--json"])
    end
  elsif under
    parent_item = resolve_ref(under)
    parent_id = stable_id_for(parent_item)
    if flags["--dry-run"]
      puts %(would nest under "#{parent_item.title}": #{item_headline(item)})
      return
    end
    result = patch_task_by_id(task_id, field: :location, value: parent_id,
                              label: "nest under #{parent_item.title}: #{item.title}", force: true)
    mutation_failed "would exceed max depth #{store.max_depth} (max_depth config / TASKS_MAX_DEPTH)" if result.too_deep?
    mutation_failed "can't nest a task under its own subtree" if result.cycle?
    mutation_result_failed(result, %(could not nest under "#{parent_item.title}"))
    report_touched([task_id], json: flags["--json"])
  else
    if flags["--dry-run"]
      puts "would move to #{section.inspect}: #{item_headline(item)}"
      return
    end
    section_id = section_id_for(section)
    mutation_failed %(could not move (no "#{section}" section?)) unless section_id
    result = patch_task_by_id(task_id, field: :location, value: section_id,
                              label: "move → #{section}: #{item.title}", force: true)
    mutation_result_failed(result, %(could not move (no "#{section}" section?)))
    report_touched([task_id], json: flags["--json"])
  end
end

DELETE_USAGE = %(tasks delete <ref> [--cascade] [--dry-run] [--json] [--include-done])

# Hard-delete a task's subtree from the live file (not the archive). A task with
# descendants is refused unless --cascade removes the whole subtree; deletion
# never reparents children. Undoable via `tasks undo`. The removed tasks are
# gone after the write, so capture their headlines BEFORE mutating and report
# from that snapshot.
def cmd_delete(args)
  flags, rest = take_flags(args, "--cascade", "--dry-run", "--json", "--include-done")
  ref = rest.shift
  abort %(usage: #{DELETE_USAGE}) if ref.nil? || ref.strip.empty?

  item = resolve_ref(ref, include_done: flags["--include-done"])
  task_id = stable_id_for(item)
  node = store.node_for(item)
  removed = node ? node.each.map(&:item).compact : [item]
  descendants = removed.length - 1

  if flags["--dry-run"]
    if descendants.positive?
      puts "would delete #{removed.length} tasks (#{descendants} descendant#{"s" unless descendants == 1}): #{item_headline(item)}"
    else
      puts "would delete: #{item_headline(item)}"
    end
    return
  end

  result = application.delete_task(task_id, cascade: flags["--cascade"])
  if result.conflict?
    n = result.summary[:descendants]
    m = result.summary[:open_descendants]
    warn "refusing to delete: #{item.title.inspect} has #{n} descendant#{"s" unless n == 1} " \
         "(#{m} open). Re-run with --cascade to remove the whole subtree."
    exit 1
  end
  mutation_result_failed(result, "failed to delete")

  if flags["--json"]
    require "json"
    puts({ deleted: removed.map { |i| item_json(i) } }.to_json)
  else
    removed.each { |i| puts item_headline(i) }
  end
end

def cmd_archive
  result = store.archive_swept!
  if result.is_a?(Tasks::Store::ArchiveRefusal)
    preview = result.preview
    if result.reason == :archive_conflict
      abort [
        "Archive refused: archive.jsonl has partial or conflicting copies of candidate IDs " \
          "#{result.details.join(", ")}.",
        "Live tasks were preserved. Compare `tasks list --done --json` with " \
          "`tasks list --archived --json`, reconcile the conflicting records, then retry.",
      ].join("\n")
    end
    blocked = preview.blocks.map do |block|
      %(#{block.root_title.inspect}: #{block.open_titles.join(", ")})
    end
    abort [
      "Archive refused: #{preview.blocked_roots} closed root#{preview.blocked_roots == 1 ? " has" : "s have"} " \
        "#{preview.open_descendants} open descendant#{preview.open_descendants == 1 ? "" : "s"}.",
      "Blocked subtree#{blocked.length == 1 ? "" : "s"}: #{blocked.join("; ")}",
      "Complete, cancel, move, or unnest the open work, then retry `tasks archive`.",
    ].join("\n")
  end
  mutation_failed("archive failed; live tasks were preserved") if result == false || store.last_rollback

  n = result
  if n.zero?
    puts "Nothing to archive (no DONE/CANCELLED items)."
  else
    puts "Archived #{n} item#{n == 1 ? "" : "s"} to archive.jsonl."
  end
end

# Revert (undo) or replay (redo) the last mutation. History is the on-disk
# journal shared with the TUI and across CLI runs, so this reaches back past the
# current invocation. Refuses when tasks.jsonl changed out-of-band since that edit.
def cmd_undo = run_history(:undo!, verb: "undo", past: "undid")
def cmd_redo = run_history(:redo!, verb: "redo", past: "redid")

# Print a task's stable :ID:, assigning one (a PROPERTIES drawer) if it has none.
# Idempotent — a task that already carries an id is printed without a rewrite.
def cmd_id(args)
  flags, rest = take_flags(args, "--json")
  ref = rest.shift
  abort "usage: tasks id <ref>" if ref.nil? || ref.strip.empty?
  item = resolve_ref(ref, include_done: true) # referenceable regardless of state
  id = store.ensure_id!(item)
  mutation_failed "failed to assign id" unless id
  store.reload!
  fresh = store.items.find { |i| i.id == id }
  if flags["--json"]
    require "json"
    puts({ id: id, touched: fresh ? [item_json(fresh)] : [] }.to_json)
  else
    puts id
    puts item_headline(fresh) if fresh
  end
end

def run_history(op, verb:, past:)
  kind, label = store.public_send(op)
  case kind
  when :empty    then abort "nothing to #{verb}"
  when :conflict then abort "tasks.jsonl changed since that edit — refusing to #{verb} “#{label}”"
  else                puts "#{past}: #{label}"
  end
end

STATE_ORDER = Tasks::TaskFilter::STATE_ORDER

# Parse `list` args into a scope symbol plus filters, then print grouped output.
def cmd_list(args)
  parsed = begin
    Tasks::TaskFilter.parse_cli(args)
  rescue ArgumentError => error
    abort error.message
  end
  result = application.list_tasks(parsed.filter)
  sel = result.items

  return if emit_json?(sel, [parsed.json ? "--json" : nil].compact, result: result)

  if sel.empty?
    puts "No matching tasks."
    return
  end

  by_state = sel.group_by(&:state)
  STATE_ORDER.each do |st|
    list = by_state[st]
    next unless list
    puts bold(st)
    list.sort_by { |i| i.priority || "Z" }.each do |i|
      due = short_due(i)
      arch = i.source == :archive ? dim("  (archived)") : ""
      defr = i.deferred? ? dim("  (deferred)") : ""
      recr = i.recur ? dim("  ↻#{i.recur}") : ""
      puts "  #{fmt(i)}#{due.empty? ? "" : "  #{due}"}#{recr}#{defr}#{arch}"
    end
    puts
  end
end

# Validate tasks.jsonl structure. Exit 0 clean, 1 errors found.
def cmd_check(args)
  res = Tasks::Check.check(ORG)
  if args.include?("--json")
    require "json"
    puts res.to_h.to_json
  else
    res.errors.each   { |line, msg| puts "#{red("error")}  line #{line}: #{msg}" }
    res.warnings.each { |line, msg| puts "#{yellow("warn")}   line #{line}: #{msg}" }
    if res.ok?
      n = store.items.size
      puts "ok — #{n} task#{n == 1 ? "" : "s"} parsed, no structural errors#{res.warnings.empty? ? "" : " (#{res.warnings.size} warning#{res.warnings.size == 1 ? "" : "s"})"}"
    else
      puts "#{res.errors.size} error(s), #{res.warnings.size} warning(s)"
    end
  end
  exit(res.ok? ? 0 : 1)
end

# Hand a natural-language prompt to an LLM agent with AGENTS.md as context.
# Runs the configured harness headless; auto-applies, then shows the file diff.
# `--provider`/`--model` (leading flags) override the config default for one run.
def cmd_prompt(args)
  provider, model, words = extract_llm_flags(Array(args))
  prompt = words.join(" ")
  abort %(usage: tasks -p [--provider NAME] [--model NAME] "do something with my tasks") if prompt.strip.empty?

  require_relative "../lib/llm/registry"
  require_relative "../lib/tasks/agent_context"
  data_dir = File.dirname(ORG)
  # Build the system context (AGENTS.md + file locations + task-set memory)
  # before spawning: an oversize/unreadable agent-memory.md must abort with the
  # path here, not run the agent without the user's saved defaults.
  sys_prompt = Tasks::AgentContext.build(paths: PATHS, cli_root: ROOT)

  entry = LLM.default_entry(provider: provider, model: model)
  agent = LLM.build(entry, root: data_dir, system: sys_prompt)
rescue ArgumentError, Tasks::AgentContext::Error => e
  abort e.message
else
  unless agent.available?
    abort "agent '#{entry.provider}' not available — check the CLI is installed and any local model server is running"
  end
  ok = agent.run_sync(prompt.strip, model: entry.model)
  warn "\n(agent exited non-zero)" unless ok
  maybe_show_diff(data_dir)
end

# Peel leading `--provider NAME` / `--model NAME` flags off the -p arguments so
# the rest is the prompt verbatim. Only strips when they lead, so a prompt that
# happens to mention "--model" mid-sentence is left untouched.
def extract_llm_flags(args)
  args = args.dup
  provider = model = nil
  loop do
    case args.first
    when "--provider" then args.shift; provider = args.shift
    when "--model"    then args.shift; model = args.shift
    else break
    end
  end
  [provider, model, args]
end

# Show what the agent changed — the task files plus the memory sidecar when it
# lives in the same repo. Only possible when the task files sit in a git repo;
# a memory sidecar relocated outside that repo can't be diffed here, so it gets
# a one-line notice instead. Decision logic lives in Tasks::AgentDiff so it can
# be tested against a real sandbox; this stays thin human formatting.
def maybe_show_diff(data_dir)
  require_relative "../lib/tasks/agent_diff"
  result = Tasks::AgentDiff.compute(data_dir: data_dir, org: ORG, archive: ARCHIVE,
                                    memory: PATHS.memory, color: $stdout.tty?)
  return unless result

  unless result.diff.strip.empty?
    puts "\n#{bold("Changes to task files:")}"
    print result.diff
    puts unless result.diff.end_with?("\n")
  end
  if result.notice
    puts dim("Note: task-set memory at #{result.notice} is outside the task-data " \
             "repo — review its changes there separately.")
  end
end

# Where the task files resolve to, and why — for debugging a config setup.
def cmd_config(args)
  if args.include?("--json")
    require "json"
    puts({ org: ORG, archive: ARCHIVE,
           memory: PATHS.memory,
           urgent_days: PATHS.urgent_days,
           max_depth: PATHS.max_depth,
           theme: PATHS.theme, colors: PATHS.colors,
           links: PATHS.links, link_systems: PATHS.link_systems,
           sources: PATHS.sources,
           memory_exists: File.file?(PATHS.memory),
           config_file: PATHS.config_file,
           config_file_exists: File.file?(PATHS.config_file) }.to_json)
  else
    puts "org:         #{ORG}  #{dim("(#{PATHS.sources[:org]})")}"
    puts "archive:     #{ARCHIVE}  #{dim("(#{PATHS.sources[:archive]})")}"
    puts "memory:      #{PATHS.memory}  #{dim("(#{PATHS.sources[:memory]}#{File.file?(PATHS.memory) ? "" : ", not present"})")}"
    puts "urgent_days: #{PATHS.urgent_days}  #{dim("(#{PATHS.sources[:urgent_days]})")}"
    puts "max_depth:   #{PATHS.max_depth}  #{dim("(#{PATHS.sources[:max_depth]})")}"
    puts "theme:       #{PATHS.theme}  #{dim("(#{PATHS.sources[:theme]})")}"
    puts "colors:      #{PATHS.colors.map { |k, v| "#{k}=#{v}" }.join(" · ")}" unless PATHS.colors.empty?
    # The link namespaces are the debugging surface for "why doesn't my
    # shorthand expand?" — show what actually resolved.
    PATHS.links.each { |n, t| puts "link.#{n}:   #{t}" }
    PATHS.link_systems.each { |n, h| puts "system.#{n}: #{h}" }
    puts "config:      #{PATHS.config_file}#{File.file?(PATHS.config_file) ? "" : dim(" (not present)")}"
  end
end

require "shellwords"

HELP = <<~USAGE
  tasks — a plain-text GTD CLI over tasks.jsonl. Every command has a short alias.

  Read:
    agenda    a              dated items, soonest first
    next      n              NEXT actions grouped by context
    quadrants q              Covey 2x2: priority (A/B) + near deadline, or tags
    inbox     i              unprocessed INBOX items
    list      l [filters]    tasks by state. Filters: @context /text +tag -A|-B|-C
                             Scope: --open/-o (default) --done/-d --archived/-x --all/-a
                             --deferred/-D someday/maybe · --recurring/-R repeating tasks
                             --body/-b widens /text search into task notes
    show      s <ref>        one task in full (headline + notes + links)
    links     urls [<ref>]   links in task notes, by system (slack, jira, …)
                             --system <name> filters · --all widens the listing
                             to done + archived (<ref> stays live-file) · --json
    open      o <ref> [n]    open a task's link in the browser (n or --system
                             picks among several; --print shows instead)
    id           <ref>       print a task's stable id (assigns one if absent)
    check     k              validate tasks.jsonl structure

  Capture:
    capture   c "text"       new item. Flags: --due --scheduled --priority
                             --tag --context --state --project --under --recur
                             (--under <ref> nests it below a task; caps at max_depth)

  Update (take <ref>; support --dry-run/--json/--include-done):
    done      d <ref>        mark DONE (cascades to open subtasks) — or roll a
                             recurring task forward (aka complete, close)
    cancel      <ref>        mark CANCELLED          (aka drop)
    state     mv <ref> <STATE>       any state transition
    due          <ref> <date>        set/replace DEADLINE   (aka deadline, reschedule)
    schedule     <ref> <date>        set/replace SCHEDULED
    undate       <ref> [--kind deadline|scheduled]   remove date stamp(s)
    priority pri <ref> <A|B|C|none>  set or clear the priority cookie
    retitle rename <ref> "title"     replace the headline title
    tag          <ref> +t -t @ctx -@ctx   add/remove tags and contexts
    note         <ref> "text"        append a body line
    move         <ref> "Section"     relocate the subtree under a heading
                 <ref> --under <ref> nest the subtree below another task (≤ max_depth)
                 <ref> --top         unnest the subtree back to the section level
    recur repeat <ref> <interval>    repeat on done: weekly · 2w · .+1m · off
                                     --from schedule|completion · --on <date>
    defer   snooze <ref>             hide a task (someday/maybe)
    activate       <ref>             bring a deferred task back (undefer, resume)
    delete         <ref>             hard-delete a task (no archive). Needs --cascade
                                     if it has subtasks. Undoable via `undo`;
                                     usually prefer cancel/archive — this is for
                                     true mistakes.

  Lifecycle:
    archive   x              sweep DONE/CANCELLED to archive.jsonl
    undo                     revert the last mutation (shared with the TUI)
    redo                     replay the last undone mutation
    config                   show resolved file paths and their sources
    -p "..."                 hand a request to an LLM agent
                             (-p [--provider N] [--model N] "...")
    help      -h             this message

  Files: default to the repo; override with TASKS_DIR (or TASKS_FILE/TASKS_ARCHIVE)
  env vars, or ~/.config/tasks/config (dir = / file = / archive = lines).
  Quadrants urgency window: urgent_days = N in the config file, or TASKS_URGENT_DAYS
  env (default 3) — a DEADLINE within N days counts as urgent.
  TUI colors: theme = default|mono|dracula|nord|catppuccin-mocha|... and
  color.<slot> = <spec> in the config file (or TASKS_THEME env; NO_COLOR
  honored) — see docs/cli-spec.md (TUI colors).
  Link shorthands: link.jira = https://acme.atlassian.net/browse/%s in the config
  lets notes say jira:OPS-1234; system.gitlab = gitlab.acme.io names custom hosts.

  Dates: 2026-07-15 · 07-15 · 7/15 · fri · today · tomorrow · +3
  Refs:  a case-insensitive title substring, an exact id, or L<line>.
  Full spec: docs/cli-spec.md
USAGE

def cmd_help(io = $stdout) = io.puts(HELP)

# each branch reads via the store on demand — `check` must be able to run
# (and report) on a file the parser would choke on
case ARGV[0]
when "-p", "--prompt" then cmd_prompt(ARGV[1..]); exit
when "next", "n"      then cmd_next(ARGV[1..])
when "quadrants", "q" then cmd_quadrants(ARGV[1..])
when "agenda", "a"    then cmd_agenda(ARGV[1..])
when "inbox", "i"     then cmd_inbox(ARGV[1..])
when "capture", "add", "c" then cmd_capture(ARGV[1..])
when "done", "complete", "close", "d" then cmd_done(ARGV[1..])
when "due", "deadline", "reschedule" then cmd_due(ARGV[1..])
when "schedule"       then cmd_schedule(ARGV[1..])
when "undate"         then cmd_undate(ARGV[1..])
when "state", "mv"    then cmd_state(ARGV[1..])
when "cancel", "drop" then cmd_cancel(ARGV[1..])
when "priority", "pri" then cmd_priority(ARGV[1..])
when "retitle", "rename" then cmd_retitle(ARGV[1..])
when "tag"            then cmd_tag(ARGV[1..])
when "note"           then cmd_note(ARGV[1..])
when "move"           then cmd_move(ARGV[1..])
when "delete"         then cmd_delete(ARGV[1..])
when "recur", "repeat", "every" then cmd_recur(ARGV[1..])
when "defer", "snooze" then cmd_defer(ARGV[1..], deferred: true,
                                      usage: "tasks defer <ref>", verb: "defer")
when "activate", "undefer", "resume" then cmd_defer(ARGV[1..], deferred: false,
                                      usage: "tasks activate <ref>", verb: "activate")
when "show", "s"      then cmd_show(ARGV[1..])
when "archive", "x"   then cmd_archive
when "undo"           then cmd_undo
when "redo"           then cmd_redo
when "id"             then cmd_id(ARGV[1..])
when "links", "urls"  then cmd_links(ARGV[1..])
when "open", "o"      then cmd_open(ARGV[1..])
when "list", "l"      then cmd_list(ARGV[1..])
when "check", "k"     then cmd_check(ARGV[1..])
when "config"         then cmd_config(ARGV[1..])
when "help", "-h", "--help" then cmd_help
else
  warn "unknown command: #{ARGV[0].inspect}\n\n" if ARGV[0]
  cmd_help($stderr)
  exit 1
end
