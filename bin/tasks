#!/usr/bin/env ruby
# frozen_string_literal: true

# tasks — a tiny CLI over gtd.org
#
# Usage (each command has a single-letter alias):
#   bin/tasks agenda|a        show items with SCHEDULED/DEADLINE, soonest first
#   bin/tasks next|n          list NEXT actions grouped by context
#   bin/tasks quadrants|q     Covey Important/Urgent 2x2
#   bin/tasks inbox|i         show unprocessed INBOX items
#   bin/tasks capture|c "..." append a new item to the Inbox
#   bin/tasks done|d "..."    mark a matching open item DONE
#   bin/tasks archive|x       move DONE/CANCELLED items to archive.org
#   bin/tasks list|l [...]    list tasks grouped by state, with filters:
#     scope:   --open/-o (default) --done/-d --archived/-x --all/-a
#     filters: @context  /text  +tag  -A|-B|-C  (compose freely)
#   bin/tasks -p "..."        hand a natural-language request to Claude (Sonnet),
#                             which acts on your tasks and reports what changed
#
# Stdlib only — no bundler required. Parses gtd.org with simple line matching.

require "date"
require "shellwords"

ROOT    = File.expand_path("..", __dir__)
ORG     = File.join(ROOT, "gtd.org")
ARCHIVE = File.join(ROOT, "archive.org")
AGENTS  = File.join(ROOT, "AGENTS.md")

Item = Struct.new(
  :state, :priority, :title, :tags, :scheduled, :deadline, :line, :source, keyword_init: true
)

HEADLINE = /^\*+\s+(INBOX|TODO|NEXT|WAITING|DONE|CANCELLED)\s+(?:\[#([ABC])\]\s+)?(.*?)\s*(:[\w@:]+:)?\s*$/
STAMP    = /(SCHEDULED|DEADLINE):\s*<(\d{4}-\d{2}-\d{2})/

def parse(files = [ORG])
  items = []
  files.each do |file|
    next unless File.exist?(file)
    src = file == ARCHIVE ? :archive : :org
    current = nil
    File.foreach(file, encoding: "UTF-8").with_index(1) do |line, lineno|
      if (m = line.match(HEADLINE))
        current = Item.new(
          state: m[1], priority: m[2], title: m[3].strip,
          tags: (m[4] || "").split(":").reject(&:empty?),
          scheduled: nil, deadline: nil, line: lineno, source: src
        )
        items << current
      elsif current && (s = line.match(STAMP))
        d = Date.parse(s[2])
        current.scheduled = d if s[1] == "SCHEDULED"
        current.deadline  = d if s[1] == "DEADLINE"
      end
    end
  end
  items
end

def contexts(item) = item.tags.select { |t| t.start_with?("@") }
def open?(item)     = OPEN_STATES.include?(item.state)

OPEN_STATES = %w[INBOX TODO NEXT WAITING].freeze
DONE_STATES = %w[DONE CANCELLED].freeze

def headline_level(line) = line.match(/^(\*+)\s+/)&.captures&.first&.length
def headline_state(line) = line[/^\*+\s+(INBOX|TODO|NEXT|WAITING|DONE|CANCELLED)\b/, 1]

def color(str, code) = $stdout.tty? ? "\e[#{code}m#{str}\e[0m" : str
def bold(s)   = color(s, 1)
def dim(s)    = color(s, 90)
def red(s)    = color(s, 31)
def yellow(s) = color(s, 33)

# Color a deadline by how close it is: red = overdue/today, yellow = next 2 days,
# cyan = this week, dim = further out.
def due_color(days)
  if    days <= 0 then 31
  elsif days <= 2 then 33
  elsif days <= 7 then 36
  else                 90
  end
end

# Short, colored deadline for `next`, e.g. "7/1" (no leading zeros).
def short_due(item)
  return "" unless item.deadline
  days  = (item.deadline - Date.today).to_i
  label = "#{item.deadline.month}/#{item.deadline.day}"
  color(label, due_color(days))
end

def fmt(item)
  pri = item.priority ? "[#{item.priority}] " : ""
  ctx = contexts(item)
  tag = ctx.empty? ? "" : dim("  #{ctx.join(" ")}")
  "#{pri}#{item.title}#{tag}"
end

def cmd_next(items)
  nexts = items.select { |i| i.state == "NEXT" }
  by_ctx = Hash.new { |h, k| h[k] = [] }
  nexts.each do |i|
    ctxs = contexts(i)
    (ctxs.empty? ? ["(no context)"] : ctxs).each { |c| by_ctx[c] << i }
  end
  by_ctx.sort.each do |ctx, list|
    puts bold(ctx)
    list.sort_by { |i| i.priority || "Z" }.each do |i|
      due = short_due(i)
      puts "  #{fmt(i)}#{due.empty? ? "" : "  #{due}"}"
    end
    puts
  end
end

def cmd_quadrants(items)
  open_items = items.select { |i| open?(i) }
  q = {
    "Q1 · Important + Urgent  (do now)"        => ->(i) { i.tags.include?("important") && i.tags.include?("urgent") },
    "Q2 · Important, Not Urgent  (schedule)"   => ->(i) { i.tags.include?("important") && !i.tags.include?("urgent") },
    "Q3 · Urgent, Not Important  (delegate)"   => ->(i) { !i.tags.include?("important") && i.tags.include?("urgent") },
    "Q4 · Neither  (eliminate)"                => ->(i) { !i.tags.include?("important") && !i.tags.include?("urgent") },
  }
  q.each do |label, test|
    puts bold(label)
    matched = open_items.select(&test)
    matched.empty? ? (puts "  —") : matched.each { |i| puts "  #{fmt(i)}" }
    puts
  end
end

def cmd_agenda(items)
  dated = items.select { |i| open?(i) && (i.scheduled || i.deadline) }
  dated.sort_by { |i| i.deadline || i.scheduled }.each do |i|
    d = i.deadline || i.scheduled
    kind = i.deadline ? "DUE " : "STRT"
    days = (d - Date.today).to_i
    when_s = days.negative? ? "#{-days}d ago" : days.zero? ? "today" : "in #{days}d"
    stamp = "#{d.strftime("%m-%d")} #{kind} (#{when_s})"
    stamp = red(stamp) if days <= 2
    puts "#{stamp}  #{fmt(i)}"
  end
end

def cmd_inbox(items)
  inbox = items.select { |i| i.state == "INBOX" }
  inbox.empty? ? (puts "Inbox empty. ✨") : inbox.each { |i| puts "  #{fmt(i)}" }
end

def cmd_capture(text)
  abort %(usage: tasks capture "...") if text.nil? || text.strip.empty?
  text = text.dup.force_encoding("UTF-8")
  lines = File.readlines(ORG, encoding: "UTF-8")
  inbox_idx = lines.index { |l| l =~ /^\* Inbox\b/ }
  abort "No '* Inbox' heading found in #{ORG}" unless inbox_idx
  # Insert just before the next top-level heading (end of the Inbox section).
  insert_idx = ((inbox_idx + 1)...lines.length).find { |i| lines[i] =~ /^\* / } || lines.length
  entry = "** INBOX #{text.strip}\n   Captured [#{Date.today}].\n\n"
  lines.insert(insert_idx, entry)
  File.write(ORG, lines.join)
  puts "Captured to Inbox: #{text.strip}"
end

def cmd_done(query)
  abort %(usage: tasks done "text") if query.nil? || query.strip.empty?
  q = query.dup.force_encoding("UTF-8").strip.downcase
  lines = File.readlines(ORG, encoding: "UTF-8")
  matches = lines.each_index.select do |i|
    st = headline_state(lines[i])
    st && OPEN_STATES.include?(st) && lines[i].downcase.include?(q)
  end
  abort "No open item matches: #{query}" if matches.empty?
  if matches.size > 1
    warn "Multiple matches — be more specific:"
    matches.each { |i| warn "  #{lines[i].strip}" }
    exit 1
  end
  i = matches.first
  lines[i] = lines[i].sub(/^(\*+\s+)(INBOX|TODO|NEXT|WAITING)\b/, '\1DONE')
  lines.insert(i + 1, "   CLOSED: [#{Date.today}]\n")
  File.write(ORG, lines.join)
  puts "Marked DONE: #{lines[i].strip}"
  puts "Run `tasks archive` to move it out of gtd.org."
end

def cmd_archive
  lines = File.readlines(ORG, encoding: "UTF-8")
  kept = []
  moved = []
  i = 0
  while i < lines.length
    st = headline_state(lines[i])
    if st && DONE_STATES.include?(st)
      level = headline_level(lines[i])
      block = [lines[i]]
      j = i + 1
      while j < lines.length
        lvl = headline_level(lines[j])
        break if lvl && lvl <= level # stop at next sibling/higher heading
        block << lines[j]
        j += 1
      end
      moved << block.join.rstrip + "\n"
      i = j
    else
      kept << lines[i]
      i += 1
    end
  end
  if moved.empty?
    puts "Nothing to archive (no DONE/CANCELLED items)."
    return
  end
  File.write(ORG, kept.join)
  arch = File.read(ARCHIVE, encoding: "UTF-8")
  arch << "\n" unless arch.end_with?("\n")
  arch << "\n# Archived #{Date.today}\n" << moved.join("\n") << "\n"
  File.write(ARCHIVE, arch)
  puts "Archived #{moved.size} item#{moved.size == 1 ? "" : "s"} to archive.org."
end

STATE_ORDER = %w[INBOX TODO NEXT WAITING DONE CANCELLED].freeze

# Parse `list` args into a scope symbol plus filters, then print grouped output.
def cmd_list(args)
  scope    = :open
  contexts_f = []
  tags_f     = []
  priority_f = nil
  text_f     = []
  args.each do |a|
    case a
    when "--open", "-o"     then scope = :open
    when "--done", "-d"     then scope = :done
    when "--archived", "-x" then scope = :archived
    when "--all", "-a"      then scope = :all
    when /\A-([ABC])\z/     then priority_f = $1
    when /\A@/              then contexts_f << a
    when /\A\+(.+)/         then tags_f << $1
    when /\A\//             then text_f << a[1..]
    when /\A-/              then abort "unknown flag: #{a}"
    else                        text_f << a # bare word = text search
    end
  end

  files =
    case scope
    when :archived then [ARCHIVE]
    when :all      then [ORG, ARCHIVE]
    else                [ORG]
    end
  items = parse(files)
  states =
    case scope
    when :open then OPEN_STATES
    when :done then DONE_STATES
    else            STATE_ORDER
    end

  q = text_f.join(" ").downcase
  sel = items.select do |i|
    states.include?(i.state) &&
      (scope != :done || i.source == :org) &&
      (priority_f.nil? || i.priority == priority_f) &&
      contexts_f.all? { |c| i.tags.include?(c) } &&
      tags_f.all?     { |t| i.tags.include?(t) } &&
      (q.empty? || i.title.downcase.include?(q))
  end

  if sel.empty?
    puts "No matching tasks."
    return
  end

  by_state = sel.group_by(&:state)
  STATE_ORDER.each do |st|
    list = by_state[st]
    next unless list
    puts bold(st)
    list.sort_by { |i| i.priority || "Z" }.each do |i|
      due = short_due(i)
      arch = i.source == :archive ? dim("  (archived)") : ""
      puts "  #{fmt(i)}#{due.empty? ? "" : "  #{due}"}#{arch}"
    end
    puts
  end
end

# Hand a natural-language prompt to Claude (Sonnet) with AGENTS.md as context.
# Runs the local `claude` CLI headless; auto-applies, then shows the file diff.
def cmd_prompt(prompt)
  abort %(usage: tasks -p "do something with my tasks") if prompt.nil? || prompt.strip.empty?
  abort "claude CLI not found on PATH" unless system("command -v claude >/dev/null 2>&1")
  sys_prompt = File.exist?(AGENTS) ? File.read(AGENTS, encoding: "UTF-8") : ""
  ok = system(
    "claude", "-p", prompt.strip,
    "--model", "sonnet",
    "--append-system-prompt", sys_prompt,
    "--output-format", "text",
    "--dangerously-skip-permissions",
    chdir: ROOT
  )
  warn "\n(claude exited non-zero)" unless ok
  diff = `git -C #{ROOT.shellescape} diff --stat -- gtd.org archive.org`
  unless diff.strip.empty?
    puts "\n#{bold("Changes to task files:")}"
    system("git", "-C", ROOT, "--no-pager", "diff", "--", "gtd.org", "archive.org")
  end
end

require "shellwords"

items = parse
case ARGV[0]
when "-p", "--prompt" then cmd_prompt(ARGV[1..].join(" ")); exit
when "next", "n"      then cmd_next(items)
when "quadrants", "q" then cmd_quadrants(items)
when "agenda", "a"    then cmd_agenda(items)
when "inbox", "i"     then cmd_inbox(items)
when "capture", "c"   then cmd_capture(ARGV[1..].join(" "))
when "done", "d"      then cmd_done(ARGV[1..].join(" "))
when "archive", "x"   then cmd_archive
when "list", "l"      then cmd_list(ARGV[1..])
else
  warn %(usage: tasks {agenda|a|next|n|quadrants|q|inbox|i|capture|c "..."|done|d "..."|archive|x|list|l [...]|-p "..."})
  exit 1
end
