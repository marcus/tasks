# Ruby
*.gem
.bundle/
vendor/bundle/

# Task data must never land in the code repo — it lives in a separate private
# repo (see ~/.config/tasks/config). Guards against a stray CLI/eval fallback
# write to the repo-root default.
/gtd.org
/gtd.org.bak
/archive.org
/archive.org.bak
# Advisory-lock sidecar Store#with_lock drops beside the org file (the undo
# journal itself lives under $XDG_STATE_HOME/tasks/, out of the repo).
/.gtd.org.lock
/.archive.org.lock

# Editor / OS
.DS_Store
*.swp
*~
\#*\#
.\#*

# launchd auto-commit log
.autocommit.log
.todos/
.sidecar/
.sidecar-agent
.sidecar-task
.sidecar-pr
.sidecar-start.sh
.sidecar-base
.td-root
